# Copy to .env and fill in. .env is gitignored (see repo .gitignore).

# Gluetun VPN credentials (Private Internet Access, OpenVPN).
# PIA username is the p####### login, NOT your email.
OPENVPN_USER=p1234567
OPENVPN_PASSWORD=your-pia-password

# TrueNAS-backed host paths on the Docker host (192.168.10.13).
# These should be NFS mounts from TrueNAS, not local container paths.
APPDATA_ROOT=/mnt/nas/appdata
MEDIA_ROOT=/mnt/nas/media
DOWNLOADS_ROOT=/mnt/nas/downloads
