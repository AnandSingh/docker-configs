# Copy to .env and change DB_PASSWORD.
# .env is gitignored.

IMMICH_VERSION=release
TZ=America/Los_Angeles

# TrueNAS-backed storage on Docker host.
IMMICH_UPLOAD_LOCATION=/media/photos/immich
IMMICH_DB_DATA_LOCATION=/home/dev/docker/appdata/immich/postgres
IMMICH_ML_CACHE_LOCATION=/home/dev/docker/appdata/immich/model-cache

DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_PASSWORD=change-me-generate-with-openssl-rand-base64-32
