# Copy to .env and fill in. .env is gitignored.

# TrueNAS-backed host paths on the Docker host (192.168.10.13).
APPDATA_ROOT=/mnt/nas/appdata
DATABASE_ROOT=/mnt/nas/databases
MEDIA_ROOT=/mnt/nas/media

# Jellystat secrets - generate with: openssl rand -base64 32
JELLYSTAT_POSTGRES_PASSWORD=change-me
JELLYSTAT_JWT_SECRET=change-me
