# eink-dashboard config. Copy to .env on the deploy host (gitignored).
# Phase 1: headless, browser-viewable, no glasses/Pi/voice.

# --- Core ---
TZ=America/Los_Angeles
VISION_PROVIDER=mock            # mock = no Anthropic key needed (no real photo capture yet)
DATA_DIR=/data
API_PORT=8080

# --- Display (Boox 32") ---
PANEL_WIDTH=2560
PANEL_HEIGHT=1440

# --- Weather: Snoqualmie, WA (manual; IP geolocation is wrong on a homelab host) ---
WEATHER_ENABLED=true
WEATHER_UNITS=fahrenheit
WEATHER_LAT=47.5287
WEATHER_LON=-121.8254
WEATHER_POLL_MINUTES=30

# --- Widgets / personal ---
BOTTOM_LEFT_WIDGET=quarter       # week | weekofyear | yearprogress | life | countdown | quarter
MOON_ENABLED=true
SUNDAY_REVIEW=true
DAILY_TICK_MINUTES=60
# BIRTHDATE=YYYY-MM-DD            # optional, enables life-in-weeks
# COUNTDOWNS=Label:YYYY-MM-DD;... # optional

# --- Calendar (optional; empty = off) ---
CALENDAR_ICS_URL=
CALENDAR_TZ=America/Los_Angeles
